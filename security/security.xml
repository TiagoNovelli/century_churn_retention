<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_retention_user" model="res.groups">
        <field name="name">Retencao / Vendedor</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="comment">Ve e edita apenas seus proprios clientes em risco.</field>
    </record>

    <record id="group_retention_coordinator" model="res.groups">
        <field name="name">Retencao / Lider de Vendas</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('group_retention_user'))]"/>
        <field name="comment">Ve e edita os clientes em risco da sua equipe.</field>
    </record>

    <record id="group_retention_manager" model="res.groups">
        <field name="name">Retencao / Gerente</field>
        <field name="category_id" ref="base.module_category_sales_sales"/>
        <field name="implied_ids" eval="[(4, ref('group_retention_coordinator'))]"/>
        <field name="comment">Acesso total incluindo importacao e configuracao.</field>
    </record>

    <record id="rule_retention_representante" model="ir.rule">
        <field name="name">Retencao: Acesso do Vendedor</field>
        <field name="model_id" ref="model_century_retention_lead"/>
        <field name="groups" eval="[(4, ref('group_retention_user'))]"/>
        <field name="domain_force">[('representante_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_retention_coordinator" model="ir.rule">
        <field name="name">Retencao: Acesso do Lider de Vendas</field>
        <field name="model_id" ref="model_century_retention_lead"/>
        <field name="groups" eval="[(4, ref('group_retention_coordinator'))]"/>
        <field name="domain_force">[('team_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_retention_manager" model="ir.rule">
        <field name="name">Retencao: Acesso do Gerente</field>
        <field name="model_id" ref="model_century_retention_lead"/>
        <field name="groups" eval="[(4, ref('group_retention_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
